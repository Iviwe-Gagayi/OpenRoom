datasource db {
  provider = "postgresql"

}

generator client {
  provider = "prisma-client-js"
}

//this will be the overall organisation like WITS, FNB etc. 

model Organization {
  id        String      @id @default(cuid())
  name      String
  members   OrgMember[]
  locations Location[]  // All spaces owned by this org
}

//this will connect Clerk account/users to organisations

model OrgMember {
  id             String       @id @default(cuid())
  userId         String       // Your Clerk User ID
  role           String       @default("MEMBER") // "ADMIN" can add locations/users
  
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  
  @@unique([userId, organizationId]) // A user can only join an org once
}

//recursive hierarchy. It's locations all the way down

model Location {
  id             String       @id @default(cuid())
  name           String
  type           String       // e.g. "CAMPUS", "BUILDING", "ROOM"
  
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])

  slotDurationMinutes Int          @default(60) // e.g., 15, 30, 60
  maxHoursPerUser     Int?         //null means unlimited
  
  parentId       String?
  parent         Location?    @relation("LocationHierarchy", fields: [parentId], references: [id], onDelete: Cascade)
  children       Location[]   @relation("LocationHierarchy")
  
  bookings       Booking[]
}

model User {
  id       String    @id
  name     String?
  bookings Booking[]
}


model Booking {
  id       String @id @default(cuid())
  slotTime String
  userId   String
  user     User   @relation(fields: [userId], references: [id])
  locationId String
  location       Location     @relation(fields: [locationId], references: [id], onDelete: Cascade)

  @@unique([locationId, slotTime])
}