datasource db {
  provider = "postgresql"

}

generator client {
  provider = "prisma-client-js"
}

//this will be the overall organisation like WITS, FNB etc. 

model Organization {
  id        String      @id @default(cuid())
  name      String

  members   OrgMember[]
  locations Location[]  // All spaces owned by this org
  invites     OrgInvite[]

  slotDurationMinutes Int          @default(60) 
  maxHoursPerUser     Int?          @default(2)
}

//this will connect Clerk account/users to organisations

model OrgMember {
  id             String       @id @default(cuid())
  userId         String       // from Clerk
  role           String       @default("MEMBER") // "ADMIN" can add locations/users
  createdAt      DateTime     @default(now())
  
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  
  @@unique([userId, organizationId]) // A user can only join an org once
}

//recursive hierarchy. It's locations all the way down

model Location {
  id             String       @id @default(cuid())
  name           String
  type           String       // e.g. "CAMPUS", "BUILDING", "ROOM"
  
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  
  parentId       String?
  parent         Location?    @relation("LocationHierarchy", fields: [parentId], references: [id], onDelete: Cascade)
  children       Location[]   @relation("LocationHierarchy")
  
  bookings       Booking[]
}

//store "whitelisted"/"invited" emails for new users to an org
model OrgInvite {
  id             String       @id @default(cuid())
  email          String
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdAt      DateTime     @default(now())

  // can't invite the same email twice to the same org
  @@unique([email, organizationId]) 
}


model Booking {
  id         String   @id @default(cuid())
  
  startTime  DateTime 
  endTime    DateTime 
  
  userId     String   
  
  locationId String
  location   Location @relation(fields: [locationId], references: [id], onDelete: Cascade)

  @@unique([locationId, startTime]) 
}